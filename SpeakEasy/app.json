{
  "expo": {
    "name": "SpeakEasy",
    "slug": "SpeakEasy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D9488"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "SpeakEasy needs microphone access to record speech therapy exercises.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.speakeasy.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D9488",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.speakeasy.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "SpeakEasy needs microphone access to record speech therapy exercises."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bf2367c4-87f6-47e5-8620-30148f8e98a2"
      }
    }
  }
}
